generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

enum MemberStatus {
  PENDING_INVITE
  INVITATION_SENT
  OTP_VERIFIED
  PROFILE_INCOMPLETE
  ACTIVE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model User {
  id              String   @id @default(cuid())
  memberId        String?  @unique
  firstName       String
  lastName        String
  email           String?  @unique
  phone           String?  @unique
  password        String?  
  role            Role     @default(MEMBER)
  familyId        String?
  gender          String?
  relationship    String?
  familyBranch    String?
  fatherId        String?
  motherId        String?
  spouseId        String?
  notes           String?
  status          MemberStatus @default(ACTIVE)
  
  avatar          String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  family          Family?  @relation(fields: [familyId], references: [id])
  memberProfile   MemberProfile?
  invitation      Invitation?
  documents       Document[]

  @@map("users")
}

model Family {
  id        String   @id @default(cuid())
  name      String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members User[]

  @@map("families")
}

model MemberProfile {
  id              String @id @default(cuid())
  userId          String @unique
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  dob             DateTime?
  bloodGroup      String?
  address         String?
  education       String?
  occupation      String?
  company         String?
  biography       String?
  socialLinks     Json?
  emergency       Json?
  documents       Json?
  privacySettings Json?

  currentStage      Int @default(1)
  profileCompletion Int @default(0)
}

model Invitation {
  id        String       @id @default(cuid())
  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String       @unique
  otp       String?      
  expiresAt DateTime
  status    InviteStatus @default(PENDING)
}

model Event {
  id              String   @id @default(cuid())
  eventId         String?  @unique
  name            String
  category        String
  description     String
  bannerImage     String?
  eventDate       DateTime
  startTime       String
  endTime         String?
  venue           String
  address         String
  city            String
  state           String
  country         String
  googleMapsUrl   String?
  organizerId     String
  familyBranch    String
  visibility      String   @default("Private")
  inviteType      String   @default("All Members")
  invitedMembers  Json?
  rsvpEnabled     Boolean  @default(false)
  maxGuests       Int?
  rsvpDeadline    DateTime?
  liveStream      Boolean  @default(false)
  streamVisibility String?
  liveChat        Boolean  @default(false)
  recordEvent     Boolean  @default(false)
  allowPhotos     Boolean  @default(true)
  allowComments   Boolean  @default(true)
  reminders       Json?    
  status          String   @default("Draft")

  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("events")
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentVisibility {
  PRIVATE
  FAMILY
  ADMIN_ONLY
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String
  size        String
  category    String
  url         String
  status      DocumentStatus @default(PENDING)
  visibility  DocumentVisibility @default(PRIVATE)
  
  uploaderId  String
  uploader    User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("documents")
}

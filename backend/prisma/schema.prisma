generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

enum MemberStatus {
  PENDING_INVITE
  INVITATION_SENT
  EMAIL_FAILED
  OTP_VERIFIED
  PROFILE_INCOMPLETE
  ACTIVE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model User {
  id              String   @id @default(cuid())
  memberId        String?  @unique
  firstName       String
  lastName        String
  email           String?  @unique
  phone           String?  @unique
  password        String?  
  role            Role     @default(MEMBER)
  familyId        String?
  gender          String?
  relationship    String?
  familyBranch    String?
  fatherId        String?
  motherId        String?
  spouseId        String?
  notes           String?
  status          MemberStatus @default(ACTIVE)
  
  avatar          String?
  isActive        Boolean  @default(true)
  profileCompletion Int @default(25)
  currentProfileStep String @default("Basic Information")
  isProfileCompleted Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  brevoErrorCode    String?
  brevoErrorMessage String?
  lastEmailAttempt  DateTime?

  family          Family?  @relation(fields: [familyId], references: [id])
  memberProfile   MemberProfile?
  memberSettings  MemberSettings?
  invitation      Invitation?
  documents       Document[]
  announcements   Announcement[]
  polls           Poll[] @relation("UserPolls")
  
  groupMembers    GroupMember[]
  groupMessages   GroupMessage[]

  @@map("users")
}

model Family {
  id        String   @id @default(cuid())
  name      String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members User[]

  @@map("families")
}

model MemberProfile {
  id              String @id @default(cuid())
  userId          String @unique
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  dob             DateTime?
  bloodGroup      String?
  address         String?
  education       String?
  occupation      String?
  company         String?
  biography       String?
  socialLinks     Json?
  emergency       Json?
  documents       Json?
  privacySettings Json?

  currentStage      Int @default(1)
  profileCompletion Int @default(0)
}

model Invitation {
  id        String       @id @default(cuid())
  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String       @unique
  otp       String?      
  expiresAt DateTime
  status    InviteStatus @default(PENDING)
}

model Event {
  id              String   @id @default(cuid())
  eventId         String?  @unique
  name            String
  category        String
  description     String
  bannerImage     String?
  eventDate       DateTime
  startTime       String
  endTime         String?
  venue           String
  address         String
  city            String
  state           String
  country         String
  googleMapsUrl   String?
  organizerId     String
  familyBranch    String
  visibility      String   @default("Private")
  inviteType      String   @default("All Members")
  invitedMembers  Json?
  rsvpEnabled     Boolean  @default(false)
  maxGuests       Int?
  rsvpDeadline    DateTime?
  liveStream      Boolean  @default(false)
  streamVisibility String?
  liveChat        Boolean  @default(false)
  recordEvent     Boolean  @default(false)
  allowPhotos     Boolean  @default(true)
  allowComments   Boolean  @default(true)
  reminders       Json?    
  status          String   @default("Draft")

  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("events")
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentVisibility {
  PRIVATE
  FAMILY
  ADMIN_ONLY
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String
  size        String
  category    String
  url         String
  status      DocumentStatus @default(PENDING)
  visibility  DocumentVisibility @default(PRIVATE)
  
  uploaderId  String
  uploader    User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("documents")
}

model MemberSettings {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  profile_photo              String?
  display_name               String?
  username                   String?  @unique
  email                      String?
  mobile                     String?
  
  theme                      String   @default("System")
  language                   String   @default("English")
  timezone                   String   @default("UTC")
  
  show_mobile                Boolean  @default(false)
  show_email                 Boolean  @default(false)
  show_dob                   Boolean  @default(false)
  show_address               Boolean  @default(false)
  show_public_profile        Boolean  @default(true)
  allow_direct_messages      Boolean  @default(true)
  
  email_notifications        Boolean  @default(true)
  whatsapp_notifications     Boolean  @default(true)
  push_notifications         Boolean  @default(true)
  birthday_notifications     Boolean  @default(true)
  event_notifications        Boolean  @default(true)
  announcement_notifications Boolean  @default(true)
  
  two_factor_enabled         Boolean  @default(false)
  updated_at                 DateTime @updatedAt

  @@map("member_settings")
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  message     String
  targetType  String   @default("All Members")
  pinned      Boolean  @default(false)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("announcements")
}

model Poll {
  id          String   @id @default(cuid())
  question    String
  options     Json     // store array of strings or objects [{id, text}]
  votes       Json     // store key/value map { "userId": optionId }
  endDate     DateTime
  authorId    String
  author      User     @relation("UserPolls", fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("polls")
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  type        String   @default("system") // e.g., 'event', 'member', 'alert'
  targetType  String   @default("All") // 'All', 'Admin', or specific userId
  isRead      Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  
  @@map("notifications")
}

model Group {
  id              String   @id @default(cuid())
  name            String
  description     String?
  category        String   @default("Immediate Family")
  coverImage      String?
  icon            String?
  privacy         String   @default("Private")
  status          String   @default("Active")
  
  allowInvites    Boolean  @default(true)
  allowPosts      Boolean  @default(true)
  allowFiles      Boolean  @default(true)
  allowPhotos     Boolean  @default(true)
  allowVideos     Boolean  @default(true)
  allowPolls      Boolean  @default(true)
  welcomeMessage  String?
  
  ownerId         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  members         GroupMember[]
  messages        GroupMessage[]
  
  @@map("groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role      String   @default("Member") // 'Admin' or 'Member'
  status    String   @default("Active") // 'Active', 'Muted'
  isMuted   Boolean  @default(false)
  
  joinedAt  DateTime @default(now())

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  type      String   @default("Text") // Text, Image, Video, File
  content   String
  fileUrl   String?
  fileName  String?
  
  createdAt DateTime @default(now())

  @@map("group_messages")
}
